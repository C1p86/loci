# ============================================================================
# xci dev environment — copy to .env for `docker compose up`.
#
#   cp .env.example .env
#
# NEVER commit .env — it is gitignored.
# .env.example IS committed (it documents the operator contract).
#
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# !! DO NOT USE THESE VALUES IN PRODUCTION.                                 !!
# !! Regenerate ALL secrets before deploying to any non-local environment.  !!
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# ============================================================================

# --- Session cookie secret (REQUIRED, min 32 chars) ---
# DEV ONLY. Generate a fresh one for production:
#   node -e "console.log(require('node:crypto').randomBytes(48).toString('hex'))"
SESSION_COOKIE_SECRET=dev-session-secret-must-be-at-least-32-chars-long

# --- Master encryption key (REQUIRED, base64 of 32 random bytes = 44 chars ending in '=') ---
# DEV ONLY. REGENERATE FOR PRODUCTION:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
#
# SECURITY WARNING: Losing this key in production makes ALL encrypted org secrets
# unrecoverable. Rotating requires calling POST /api/admin/rotate-mek (see runbook
# in packages/server/README.md). Back it up in a secrets manager before deploying.
XCI_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# --- Platform admin email (REQUIRED) ---
# The ONE account allowed to call POST /api/admin/rotate-mek.
# Must match a real user email that has signed up. Comparison is case-insensitive.
PLATFORM_ADMIN_EMAIL=admin@localhost

# --- Database URL (REQUIRED in production; compose overrides this at the network level) ---
# Format: postgres://user:password@host:port/database
# In docker compose, DATABASE_URL is overridden to point at the compose-internal
# "postgres" hostname (postgres://xci:xci_dev_password@postgres:5432/xci).
DATABASE_URL=postgresql://xci:xci_dev_password@localhost:5432/xci

# --- Email transport (REQUIRED) ---
# Options: log | stub | smtp
#   log:  logs email bodies to stdout (best for local dev without mailhog)
#   stub: discards emails (CI / test usage)
#   smtp: uses SMTP_HOST + SMTP_PORT + SMTP_FROM (+ optional SMTP_USER / SMTP_PASS)
#
# Compose overrides this to "smtp" pointing at the mailhog service.
EMAIL_TRANSPORT=smtp

# --- SMTP config (REQUIRED only if EMAIL_TRANSPORT=smtp) ---
# Compose overrides SMTP_HOST, SMTP_PORT, and SMTP_FROM to point at the mailhog container.
# For production: use your real SMTP relay (SES, SendGrid, Postmark, etc.).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=xci-dev@localhost

# --- Postgres credentials for the compose stack ---
# These are consumed by the "postgres" service in docker-compose.yml.
# Compose also interpolates them into DATABASE_URL for the server service.
POSTGRES_USER=xci
POSTGRES_PASSWORD=xci_dev_password
POSTGRES_DB=xci

# --- Optional overrides ---
# NODE_ENV=production          # image default; set to development for pino-pretty logs
# PORT=3000                    # image default
# LOG_LEVEL=info               # fatal|error|warn|info|debug|trace
# LOG_RETENTION_INTERVAL_MS=86400000   # 24h log retention cleanup cadence
# WEB_STATIC_ROOT=/app/web     # image default — serve @xci/web SPA at /
#                              # set to '' to disable static serving (API-only mode)
# APP_BASE_URL=http://localhost:3000   # canonical URL prefix for transactional email links (verify-email, password-reset, invite).
#                                      # No trailing slash. Pattern: ^https?://. When unset, falls back to `https://<Host header>` from the incoming request.
#                                      # Docker compose sets this explicitly; production should set it to your public https URL.
