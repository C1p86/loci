{
  "name": "xci",
  "version": "0.0.0",
  "description": "Local CI — cross-platform command alias runner with layered YAML config",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.5.0"
  },
  "bin": {
    "xci": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke": "node dist/cli.mjs --version",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "14.0.3",
    "execa": "9.6.1",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/node": "^22",
    "tsup": "8.5.1",
    "typescript": "^5.9.0",
    "vitest": "4.1.4"
  }
}
