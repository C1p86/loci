# Monorepo noise
node_modules
**/node_modules
.pnpm-store
# Planning & docs
.planning
**/*.md
!packages/server/package.json
# Git & CI
.git
.github
.gitignore
.gitattributes
# Tests & fixtures (server tests run in CI, not in image)
**/__tests__
**/*.test.ts
**/*.test.js
**/*.spec.ts
**/coverage
**/.vitest-output
# Build artifacts that we regenerate in builder stage
**/dist
**/.turbo
packages/server/tsconfig.tsbuildinfo
packages/web/tsconfig.tsbuildinfo
packages/xci/tsconfig.tsbuildinfo
# xci package: builder stage needs source to build (turbo runs xci:build),
# but TestProject is a v1 fixture not needed for any build.
packages/xci/TestProject
# web source files: REQUIRED in builder stage for `tsc -b && vite build`.
# Runtime stage only COPYs packages/web/dist from builder, so source never
# reaches the final image. Do NOT exclude from build context.
packages/web/e2e
packages/web/playwright.config.ts
# Editor
.vscode
.idea
# Env files — NEVER in image
.env
.env.*
!.env.example
